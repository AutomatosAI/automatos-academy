# Automatos Academy — environment variables.
# Copy to .env for local use; Railway env vars in deploys. No value here is a
# real secret.

# ── Spine — per-user state API (PRD-MT-02) ─────────────────────────────
# Default OFF: without SPINE_ENABLED=true the service boots as a pure
# static/catalog server and needs NONE of the values in this block. With it,
# missing DATABASE_URL or CLERK_SECRET_KEY fails the boot loudly.
SPINE_ENABLED=false

# Postgres for user state (Railway Postgres, D-R3). Requires PostgreSQL >= 15.
# Run `npm run migrate` against it once per deploy.
DATABASE_URL=postgres://user:password@host:5432/academy_spine

# Clerk tenant (D-R6 / D-U1 — production instance shared with the mobile app).
# The secret key verifies session tokens server-side and powers the
# account-deletion call. The publishable key is the client half: server.js
# hydrates it into public/auth-config.js at boot (PRD-U1), which is what makes
# the web sign-in button appear — it is read even when SPINE_ENABLED=false
# (sign-in without sync boots, with a warning). Unset → no auth UI at all.
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Comma-separated origins accepted as the session token's authorized party
# (azp) — PRD-U1 S3 hardening. When set, verifyToken refuses tokens minted for
# any other app/origin on the same Clerk instance. Set it in production (site
# origin + any Railway preview origin that should sign in); unset skips the
# azp check (dev-only convenience).
ACADEMY_AUTHORIZED_PARTIES=https://academy.automatos.app

# ── Existing service vars (unchanged by PRD-MT-02) ─────────────────────
# BADGE_SIGNING_SECRET=        # HMAC key for signed badge links (dev default if unset)
# NOTIFY_WEBHOOK_URL=          # notify-me capture forward target (503 if unset)
# ACADEMY_CHAT_PUBLIC_KEY=     # tutor chat public key (safe default baked in)
# ACADEMY_CHAT_AGENT_ID=       # tutor agent id
# ACADEMY_ANALYTICS_ENDPOINT=  # optional analytics sink
# CONTENT_JOURNAL_PATH=        # content-version journal location (defaults to ./data)
